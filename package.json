{
  "name": "e-commerce",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,green \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --cwd frontend build",
    "lint": "bun run --cwd frontend lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^6.0.3"
  }
}
